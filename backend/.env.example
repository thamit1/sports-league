# ─── App ──────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-this-jwt-secret-too

# ─── Database ─────────────────────────────────────────────────────
# SQLite (default — zero setup, just run the app)
DB_TYPE=sqlite
# SQLITE_FILE is optional; defaults to slms.db in the project root

# MySQL (uncomment + fill in to switch to MySQL)
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=slms_db
# DB_USER=slms_user
# DB_PASSWORD=your_password
